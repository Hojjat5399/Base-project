import random
import sys

class CryptoCoinFlipGame:
    def __init__(self, initial_balance=100.0, currency="ETH"):
        self.balance = initial_balance
        self.currency = currency
        self.rounds_played = 0

    def show_balance(self):
        print(f"\nBalance: {self.balance:.4f} {self.currency}")

    def flip_coin(self):
        return random.choice(['heads', 'tails'])

    def place_bet(self, amount, choice):
        if amount <= 0:
            return None, "Bet amount must be greater than zero."
        if amount > self.balance:
            return None, "Insufficient balance."
        if choice not in ['heads', 'tails']:
            return None, "Invalid choice. Use 'heads' or 'tails'."

        result = self.flip_coin()
        win = (choice == result)

        if win:
            profit = amount
            self.balance += profit
            message = f"You won! Coin shows {result}. You gained {profit:.4f} {self.currency}."
        else:
            profit = -amount
            self.balance += profit
            message = f"You lost! Coin shows {result}. You lost {amount:.4f} {self.currency}."

        self.rounds_played += 1
        return result, message, profit

    def play_round(self):
        print("\n" + "="*50)
        print("New round - Coin Flip")
        self.show_balance()

        try:
            amount = float(input(f"Bet amount (max {self.balance:.4f} {self.currency}): "))
        except ValueError:
            print("Invalid number.")
            return

        choice = input("Choose heads or tails: ").strip().lower()

        result, msg, profit = self.place_bet(amount, choice)

        if result is None:
            print(f"Error: {msg}")
            return

        print(f"\n{msg}")
        self.show_balance()
        print(f"Rounds played: {self.rounds_played}")

    def start(self):
        print("Welcome to Crypto Coin Flip Game!")
        print(f"Initial balance: {self.balance:.4f} {self.currency}")
        print("Bet on heads or tails. If correct, you double your bet.")
        print("Type 'exit' to quit.\n")

        while True:
            self.play_round()
            if self.balance <= 0:
                print("\nBalance is zero. Game over!")
                break

            cont = input("\nContinue? (y/n): ").strip().lower()
            if cont != 'y':
                print("\nThanks for playing! Final balance:")
                self.show_balance()
                break


# --- NEW ADDITION: Simulation function ---
def run_simulation(num_games=5):
    """Runs a number of random games automatically and shows summary stats."""
    print("\n--- Running a quick simulation of {} random games ---".format(num_games))
    sim_game = CryptoCoinFlipGame(initial_balance=100.0, currency="ETH")
    wins = 0
    for i in range(num_games):
        amount = random.uniform(5, 20)          # random bet between 5 and 20
        choice = random.choice(['heads', 'tails'])
        result, msg, profit = sim_game.place_bet(amount, choice)
        if profit > 0:
            wins += 1
        print(f"Game {i+1}: {msg}")
    print(f"\nSimulation result: {wins} wins out of {num_games}, "
          f"final balance: {sim_game.balance:.4f} {sim_game.currency}")


if __name__ == "__main__":
    game = CryptoCoinFlipGame(initial_balance=100.0, currency="ETH")
    game.start()                # play the main interactive game
    run_simulation()            # automatically run a demo after the game ends
